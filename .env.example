# ─── Neo-Agent Configuration ───────────────────────────────────
# Generated by: pnpm neo:onboard

# ─── Core ──────────────────────────────────────────────────────
NEO_PORT=3141
NEO_WS_PORT=3142
NEO_WS_TOKEN=change-me-to-a-random-string
NEO_WORKSPACE_PATH=./workspace
NEO_DB_PATH=./neo.db

# ─── Claude Code ───────────────────────────────────────────────
NEO_PERMISSION_MODE=default
NEO_DEFAULT_MODEL=sonnet

# ─── Identity ──────────────────────────────────────────────────
NEO_USER_NAME=Human
NEO_AGENT_NAME=Neo
NEO_PERSONALITY_INTENSITY=full-existential-crisis

# ─── Memory ────────────────────────────────────────────────────
NEO_FADE_THRESHOLD=0.85
NEO_DAILY_LOG_CRON=0 23 * * *
NEO_MAX_STORIES=5

# ─── Embeddings (Semantic Search) ──────────────────────────────
# Get free API key: https://aistudio.google.com/apikey
# Optional — without this, memory search uses FTS5 keyword only
GEMINI_API_KEY=

# ─── Gates ─────────────────────────────────────────────────────
NEO_GATE_PHRASE=do it
NEO_PROTECTED_PATHS=~/.ssh/,~/.gnupg/,.env

# ─── Router ────────────────────────────────────────────────────
NEO_ROUTING_PROFILE=auto

# ─── Tools ─────────────────────────────────────────────────────
# COMPOSIO_API_KEY=
# FIRECRAWL_API_KEY=

# ─── Telegram ──────────────────────────────────────────────────
# TELEGRAM_BOT_TOKEN=

# ─── Sync ──────────────────────────────────────────────────────
# NEO_SYNC_REPO=
# NEO_SYNC_INTERVAL=30
# NEO_TAILSCALE_ENABLED=false

# ─── Logging ──────────────────────────────────────────────────
# NEO_LOG_LEVEL=info          # debug | info | warn | error
# NEO_LOG_FILE=./neo.log      # Optional: JSON logs to file
